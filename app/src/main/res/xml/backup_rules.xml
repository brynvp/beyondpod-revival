<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for API < 31.
    The Room database is excluded from cloud backup. Episode state, download progress,
    and subscriptions are either re-fetched from RSS on first launch or will be handled
    by gPodder sync in a future release. Backing up and restoring the DB causes stale
    download states (DOWNLOADING/DOWNLOADED) to reappear after "Clear Data", which is
    confusing and hard to debug.
    DataStore preferences (settings) ARE backed up — those are safe to restore.
-->
<full-backup-content>
    <!-- Exclude Room DB + WAL/SHM journal files -->
    <exclude domain="database" path="beyondpod.db"/>
    <exclude domain="database" path="beyondpod.db-shm"/>
    <exclude domain="database" path="beyondpod.db-wal"/>
    <!-- Exclude WorkManager's internal DB so stale job queues aren't restored -->
    <exclude domain="database" path="workdb"/>
    <exclude domain="database" path="workdb-shm"/>
    <exclude domain="database" path="workdb-wal"/>
</full-backup-content>