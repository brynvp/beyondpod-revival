<?xml version="1.0" encoding="utf-8"?>
<!-- Single row in the FeedListWidget ListView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="4dp">

    <!-- State bar (left border) -->
    <View
        android:id="@+id/widget_item_state_bar"
        android:layout_width="3dp"
        android:layout_height="40dp"
        android:background="#FF1565C0" />

    <!-- Episode artwork -->
    <ImageView
        android:id="@+id/widget_item_artwork"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:contentDescription=""
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher" />

    <!-- Text content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_item_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>
