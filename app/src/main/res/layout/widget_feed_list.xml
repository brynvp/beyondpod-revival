<?xml version="1.0" encoding="utf-8"?>
<!-- FeedListWidget — scrollable list of recent unplayed episodes -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="@string/widget_recent_episodes"
        android:textColor="#B35E92F3"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <!-- Scrollable episode list -->
    <ListView
        android:id="@+id/widget_episode_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp" />

    <!-- Empty state (hidden when list has items) -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/widget_no_episodes"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
