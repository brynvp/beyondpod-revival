<?xml version="1.0" encoding="utf-8"?>
<!-- PlayerWidget — 4×1 strip: artwork | title+feed | skip-back play/pause skip-forward -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- Episode artwork -->
    <ImageView
        android:id="@+id/widget_artwork"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/widget_artwork_desc"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher" />

    <!-- Title + feed name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_episode_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_no_episode"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_feed_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="#B3FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Skip back -->
    <ImageButton
        android:id="@+id/widget_skip_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/widget_skip_back_desc"
        android:src="@drawable/ic_widget_skip_back" />

    <!-- Play / Pause -->
    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/widget_play_pause_desc"
        android:src="@drawable/ic_widget_play" />

    <!-- Skip forward -->
    <ImageButton
        android:id="@+id/widget_skip_forward"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/widget_skip_forward_desc"
        android:src="@drawable/ic_widget_skip_forward" />

</LinearLayout>
